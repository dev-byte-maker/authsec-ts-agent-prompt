AUTHSEC_ISSUER=https://stage.api.authsec.dev
AUTHSEC_AUTHORIZATION_SERVER=https://stage.api.authsec.dev
AUTHSEC_JWKS_URL=https://stage.api.authsec.dev/oauth/jwks
AUTHSEC_INTROSPECTION_URL=https://stage.api.authsec.dev/oauth/introspect

AUTHSEC_INTROSPECTION_CLIENT_ID=<your-resource-server-uuid>
AUTHSEC_INTROSPECTION_CLIENT_SECRET=<one-time-secret-from-authsec-panel>

AUTHSEC_RESOURCE_URI=https://authsec-ts-agent-prompt.onrender.com/mcp
AUTHSEC_RESOURCE_NAME=ts-agent-prompt
AUTHSEC_RESOURCE_SERVER_ID=<your-resource-server-uuid>

AUTHSEC_POLICY_MODE=remote_required
AUTHSEC_VALIDATION_MODE=jwt_and_introspect
AUTHSEC_PUBLISH_MANIFEST=true

PORT=8000
