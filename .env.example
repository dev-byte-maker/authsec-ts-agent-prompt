# =============================================================================
# AuthSec Runtime Configuration
# Copy to .env and fill in secrets from the AuthSec Application detail page.
# =============================================================================

# --- AuthSec endpoints (stage) -----------------------------------------------
AUTHSEC_ISSUER=https://stage.api.authsec.dev
AUTHSEC_AUTHORIZATION_SERVER=https://stage.api.authsec.dev
AUTHSEC_JWKS_URL=https://stage.api.authsec.dev/oauth/jwks
AUTHSEC_INTROSPECTION_URL=https://stage.api.authsec.dev/oauth/introspect

# --- Resource server identity (copy from AuthSec UI "Show config") -----------
# AUTHSEC_RESOURCE_SERVER_ID=<uuid-from-authsec>
# AUTHSEC_RESOURCE_URI=https://authsec-ts-agent-prompt.onrender.com/mcp
# AUTHSEC_RESOURCE_NAME=mcp-render-ts-agent-setup

# --- Introspection credentials (from AuthSec UI) -----------------------------
# AUTHSEC_INTROSPECTION_CLIENT_ID=<same-as-resource-server-id>
# AUTHSEC_INTROSPECTION_CLIENT_SECRET=<one-time-secret-from-authsec>

# --- Canonical scopes advertised in protected-resource metadata --------------
AUTHSEC_SUPPORTED_SCOPES=mcp_render_ts_agent_setup:read mcp_render_ts_agent_setup:tools:read mcp_render_ts_agent_setup:tools:write mcp_render_ts_agent_setup:write

# --- SDK behaviour -----------------------------------------------------------
# remote_required: fetch tool→scope policy from AuthSec; fail loudly if unavailable
AUTHSEC_POLICY_MODE=remote_required
# jwt_and_introspect: verify JWT signature then introspect to catch revoked tokens
AUTHSEC_VALIDATION_MODE=jwt_and_introspect
# Publish tool inventory to AuthSec on startup so admins can bind scopes in UI
AUTHSEC_PUBLISH_MANIFEST=true

# --- Server ------------------------------------------------------------------
PORT=3000
